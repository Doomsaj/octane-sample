# Copy to .env (or export in your shell) before running with GHCR images.
#
# Replace <owner> with your GitHub username / org.
# Replace <repo>  with the repository name (usually octane-sample).
#
# The GitHub Actions workflow pushes to:
#   ghcr.io/<owner>/<repo>:fpm-latest
#   ghcr.io/<owner>/<repo>:octane-latest
#   ghcr.io/<owner>/<repo>:fpm-sha-<short-sha>
#   ghcr.io/<owner>/<repo>:octane-sha-<short-sha>

GHCR_IMAGE=ghcr.io/<owner>/<repo>

# Pin to a specific SHA or version, or use *-latest for the most recent build
FPM_TAG=fpm-latest
OCTANE_TAG=octane-latest
